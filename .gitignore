# 실데이터·백업은 절대 커밋하지 않는다 (PII/회사 기밀 — DATA_DIR 밖에서 관리)
Data/*.csv
Data/*.xlsx
Data/backups/
!Data/.gitkeep

# 생성된 내보내기 파일(매핑 점수 = 회사 기밀) — 커밋 금지
*.xlsx

# 파이썬/환경
.venv/
__pycache__/
*.pyc
*.pyo

# 도구·OS 산출물
.playwright-mcp/
.tools/
*.png
.DS_Store
/tmp/

# 런타임 DB (git 제외)
*.db
app.db
*.db-wal
*.db-shm
*.db-journal
*.db.bak*

# 로컬 전용 Claude 설정 (학습 모드 등) — 공개 커밋 제외
.claude/settings.local.json

# 배포 시크릿 (htpasswd 해시 포함) — 절대 커밋 금지
k8s/secret-*.yaml

# 회의 원문(STT) — PII/회사 기밀 (요약본 meetings/summary 는 추적). 폴더 구조만 .gitkeep 로 유지
meetings/raw/*
!meetings/raw/.gitkeep

# 문서폴더
dics/*

# Local documents
docs/

# 문서 다운로드 자동화 — 암호화된 비밀번호 파일/로그 (절대 커밋 금지)
scripts/.docs_password.xml
scripts/*.log

# R2 동기화 자격증명/설정 (절대 커밋 금지)
scripts/.r2_credentials.xml
scripts/r2_sync.config.json

# SW 대가 게시판 모니터링 — 암호화된 PAT (절대 커밋 금지)
scripts/.sw_guide_token.xml

# Worker 워치독 — 암호화된 Cloudflare API 토큰 (절대 커밋 금지)
scripts/.cf_api_token.xml

# NotebookLM 동기화 — 암호화된 Google OAuth 자격증명 (절대 커밋 금지)
scripts/.notebooklm_creds.xml

# Claude headless 인증 — 암호화된 ANTHROPIC_API_KEY (절대 커밋 금지)
scripts/.anthropic_api_key.xml

# Claude 자동 기록 보류 표식 (기기 로컬 상태 — 커밋하지 않음)
scripts/.claude_ask_paused

# Obsidian 볼트 — 기기/앱 버전마다 달라지는 로컬 설정은 제외 (실제 설정 차이 없이 노이즈만 생김)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.obsidian/plugins/*/data.json
.obsidian/app.json
.obsidian/appearance.json
.obsidian/core-plugins.json

# GitHub Wiki publish working clone
.wiki-worktree/
